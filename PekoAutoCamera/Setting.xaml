<Page x:Class="PekoAutoCamera.Setting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PekoAutoCamera"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Setting">

    <Grid Background="#FF75D0DC">
        <Label Content="PEKO PEKO BATTLE カメラ制御ツール" HorizontalAlignment="Center" Margin="0,62,0,0" VerticalAlignment="Top" FontSize="36"/>
        <Label Content="ログパス" HorizontalAlignment="Left" Margin="138,165,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="logpath_txt" HorizontalAlignment="Left" Margin="230,169,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="498" TextChanged="TextBox_TextChanged"/>
        <Button Content="開始" HorizontalAlignment="Center" Margin="0,277,0,0" VerticalAlignment="Top" Click="Button_Click" Height="64" Width="152"/>
        <Label Content="OSC送信先" HorizontalAlignment="Left" Margin="138,196,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="osc_address" HorizontalAlignment="Left" Margin="230,200,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="246" TextChanged="TextBox_TextChanged_1"/>
        <Label Content="OSCポート" HorizontalAlignment="Left" Margin="569,196,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="osc_port" HorizontalAlignment="Left" Margin="657,200,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="71" TextChanged="TextBox_TextChanged_1" PreviewTextInput="TextBox_PreviewTextInput"/>

    </Grid>
</Page>
